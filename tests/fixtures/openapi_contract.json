{
  "openapi": "3.0.0",
  "components": {
    "schemas": {
      "Base": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"}
        },
        "required": ["id"]
      },
      "Ticket": {
        "allOf": [
          {"$ref": "#/components/schemas/Base"},
          {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "state": {
                "oneOf": [
                  {"type": "string"},
                  {"type": "integer"}
                ]
              }
            }
          }
        ]
      }
    }
  },
  "paths": {
    "/Ticket/{id}": {
      "get": {
        "operationId": "getTicket",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}},
          {"name": "expand", "in": "query", "required": true, "schema": {"type": "integer"}},
          {"name": "X-Tenant", "in": "header", "required": true, "schema": {"type": "string"}},
          {"name": "session", "in": "cookie", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Ticket"}
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateTicket",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {"name": {"type": "string"}}
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "integer"},
                    "updated": {"type": "boolean"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/Ticket": {
      "post": {
        "operationId": "createTicket",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {"name": {"type": "string"}}
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "integer"},
                    "created": {"type": "boolean"}
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
